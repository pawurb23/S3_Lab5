<Window x:Class="S3_Lab5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zarządzanie Pływakami" Height="450" Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <ListBox Grid.Row="0" Grid.Column="0" 
                 ItemsSource="{Binding Plywacy}" 
                 SelectedItem="{Binding WybranyPlywak}"
                 DisplayMemberPath="Wizytowka" Margin="0,0,5,0"/>

        <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,0,0" DataContext="{Binding Formularz}">
            <TextBlock Text="Imię i nazwisko:" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox Text="{Binding ImieNazwisko}" Margin="0,0,0,10"/>

            <TextBlock Text="Rok urodzenia:" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox Text="{Binding RokUrodzenia}" Margin="0,0,0,10"/>

            <TextBlock Text="Najlepszy czas na 50m (s):" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox Text="{Binding NajlepszyCzas}" Margin="0,0,0,10"/>

            <CheckBox Content="Czy aktywny zawodnik?" IsChecked="{Binding CzyAktywnyZawodnik}" Margin="0,0,0,10"/>

            <TextBlock Text="Ilość złotych medali:" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox Text="{Binding IloscZlotychMedali, TargetNullValue=''}" Margin="0,0,0,10"/>

            <Button Content="Wyczyść formularz (Nowy)" Click="BtnWyczysc_Click" Margin="0,10,0,0" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Min/Max Czas" Click="BtnMinMax_Click" Margin="5" Padding="10,5" Background="LightBlue"/>
            <Button Content="Dodaj nowego" Click="BtnDodaj_Click" Margin="5" Padding="10,5"/>
            <Button Content="Zapisz zmiany" Click="BtnZapisz_Click" Margin="5" Padding="10,5" FontWeight="Bold"/>
            <Button Content="Usuń wybranego" Click="BtnUsun_Click" Margin="5" Padding="10,5" Foreground="Red"/>
        </StackPanel>
    </Grid>
</Window>